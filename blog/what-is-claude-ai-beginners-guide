<script>
/* Animated canvas background */
(function(){
  const canvas=document.getElementById('bg-canvas');
  const ctx=canvas.getContext('2d');
  let W,H,particles=[];
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
  resize();window.addEventListener('resize',resize);
  for(let i=0;i<55;i++){
    particles.push({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,r:Math.random()*1.5+0.3,vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3,o:Math.random()*0.4+0.1});
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<particles.length;i++){
      for(let j=i+1;j<particles.length;j++){
        const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y;
        const dist=Math.sqrt(dx*dx+dy*dy);
        if(dist<140){ctx.beginPath();ctx.strokeStyle=`rgba(108,99,255,${0.06*(1-dist/140)})`;ctx.lineWidth=0.8;ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.stroke()}
      }
    }
    particles.forEach(p=>{
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(167,139,250,${p.o})`;ctx.fill();
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

/* Footer rising particles */
(function(){
  const container=document.getElementById('footer-particles');
  if(!container)return;
  for(let i=0;i<18;i++){
    const dot=document.createElement('div');
    dot.className='fparticle';
    dot.style.cssText=`
      left:${Math.random()*100}%;
      bottom:${Math.random()*30}%;
      width:${Math.random()*2+1}px;
      height:${Math.random()*2+1}px;
      animation-duration:${Math.random()*4+3}s;
      animation-delay:${Math.random()*4}s;
    `;
    container.appendChild(dot);
  }
})();

/* Progress bar + back to top */
window.addEventListener('scroll',function(){
  const st=window.scrollY,dh=document.body.scrollHeight-window.innerHeight;
  document.getElementById('progress-bar').style.width=(st/dh*100)+'%';
  const btt=document.getElementById('btt');
  st>400?btt.classList.add('show'):btt.classList.remove('show');
});

