<script type="application/ld+json">{"@context":"https://schema.org","@type":"Article","headline":"How to Build a Daily Workflow Using AI Tools","description":"Learn how to build a daily workflow using AI tools that saves real time, removes friction, and keeps your output quality high every single day.","image":"https://nyvoraai.github.io/assets/blog/how-to-build-a-daily-workflow-using-ai-tools-thumbnail.png","datePublished":"2026-07-01","dateModified":"2026-07-01","author":{"@type":"Person","name":"Varun Lalwani","url":"https://nyvoraai.github.io/about.html"},"publisher":{"@type":"Organization","name":"NyvoraAI","url":"https://nyvoraai.github.io","logo":{"@type":"ImageObject","url":"https://nyvoraai.github.io/assets/logo.png"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://nyvoraai.github.io/blog/how-to-build-a-daily-workflow-using-ai-tools.html"}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://nyvoraai.github.io/index.html"},{"@type":"ListItem","position":2,"name":"Blog","item":"https://nyvoraai.github.io/blog.html"},{"@type":"ListItem","position":3,"name":"How to Build a Daily Workflow Using AI Tools","item":"https://nyvoraai.github.io/blog/how-to-build-a-daily-workflow-using-ai-tools.html"}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How do I build a daily workflow using AI tools?","acceptedAnswer":{"@type":"Answer","text":"Start by identifying tasks in your day that are slow or repetitive, assign an AI tool to each one, build the workflow gradually one task at a time, and review what actually saves time versus what adds friction."}},{"@type":"Question","name":"Which AI tools are best for a daily productivity workflow?","acceptedAnswer":{"@type":"Answer","text":"The best AI tools for a daily workflow depend on your work type. Writers benefit from AI drafting assistants, content creators from caption and scheduling tools, and knowledge workers from AI summarisation and meeting note tools."}},{"@type":"Question","name":"How many hours can an AI workflow save per day?","acceptedAnswer":{"@type":"Answer","text":"Most people who build a consistent AI-assisted daily workflow report saving between one and three hours per day, primarily by reducing time spent on drafting, research, and repetitive communication tasks."}},{"@type":"Question","name":"Will an AI daily workflow make my work feel generic?","acceptedAnswer":{"@type":"Answer","text":"Only if you use AI output without editing it. A well-designed workflow uses AI to handle the slow structural parts of a task and keeps you responsible for judgment, voice, and final review."}},{"@type":"Question","name":"How long does it take to build a good AI workflow?","acceptedAnswer":{"@type":"Answer","text":"Most people have a functional, time-saving AI workflow running within two to three weeks, since it takes a few cycles of real use to learn which tools fit which tasks and which prompts produce the most useful first drafts."}}]}</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080A0F;--bg-2:#0D1117;--bg-3:#111827;--bg-card:#141B26;--bg-card-2:#1A2235;
  --border:#1E2D40;--border-bright:#2A3F5C;
  --cyan:#00D4FF;--cyan-dim:#0099BB;--cyan-glow:rgba(0,212,255,0.15);
  --violet:#7B5EA7;--violet-bright:#9B7EC8;
  --green:#00E5A0;--green-dim:#00B07A;
  --amber:#FFB347;--red:#FF6B6B;--pink:#FF69B4;--orange:#FF8C42;
  --text:#E8EDF5;--text-2:#9BA8BC;--text-3:#5C6B80;--text-inv:#080A0F;
  --radius:16px;--radius-sm:10px;
  --font-display:'Space Grotesk',system-ui,sans-serif;
  --font-body:'Inter',system-ui,sans-serif;
  --font-mono:'JetBrains Mono','Courier New',monospace;
  --glow-cyan:0 0 30px rgba(0,212,255,0.2),0 0 60px rgba(0,212,255,0.08);
  --shadow-card:0 4px 24px rgba(0,0,0,0.4),0 1px 4px rgba(0,0,0,0.3);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:17px;line-height:1.78;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:var(--cyan);text-decoration:none;transition:color .2s}
a:hover{color:var(--cyan-dim);text-decoration:underline}
h1,h2,h3{font-family:var(--font-display)}
:focus-visible{outline:2px solid var(--cyan);outline-offset:3px}
.bg-canvas{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.stars{position:absolute;inset:0}
.star{position:absolute;background:#fff;border-radius:50%;animation:starTwinkle ease-in-out infinite}
@keyframes starTwinkle{0%,100%{opacity:.15;transform:scale(1)}50%{opacity:.8;transform:scale(1.4)}}
.aura{position:absolute;border-radius:50%;filter:blur(100px);will-change:transform;animation:auraFloat ease-in-out infinite;pointer-events:none}
.aura-1{width:700px;height:700px;background:radial-gradient(circle,rgba(0,212,255,.18),transparent 65%);top:-200px;left:-200px;animation-duration:20s}
.aura-2{width:600px;height:600px;background:radial-gradient(circle,rgba(123,94,167,.22),transparent 65%);bottom:-150px;right:-150px;animation-duration:25s;animation-delay:-8s}
.aura-3{width:500px;height:500px;background:radial-gradient(circle,rgba(0,229,160,.12),transparent 65%);top:40%;left:55%;animation-duration:18s;animation-delay:-4s}
@keyframes auraFloat{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(60px,-50px) scale(1.1)}66%{transform:translate(-40px,35px) scale(.92)}}
.grid-lines{position:absolute;inset:0;background-image:linear-gradient(rgba(0,212,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,212,255,.025) 1px,transparent 1px);background-size:60px 60px;animation:gridShift 40s linear infinite}
@keyframes gridShift{0%{background-position:0 0}100%{background-position:60px 60px}}
.orb{position:absolute;border-radius:50%;animation:orbFloat ease-in-out infinite;opacity:0}
@keyframes orbFloat{0%{transform:translateY(110vh) scale(.5);opacity:0}10%{opacity:.6}90%{opacity:.3}100%{transform:translateY(-10vh) scale(1.2);opacity:0}}
@media(prefers-reduced-motion:reduce){.star,.aura,.orb,.grid-lines{animation:none;display:none}html{scroll-behavior:auto}}
#progress{position:fixed;top:0;left:0;width:0;height:2px;z-index:400;background:linear-gradient(90deg,var(--cyan),var(--violet-bright),var(--green));transition:width .08s;box-shadow:0 0 12px var(--cyan)}
nav{position:sticky;top:0;z-index:300;background:rgba(8,10,15,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:62px;position:relative;z-index:1}
.nav-logo{font-family:var(--font-display);font-size:20px;font-weight:700;letter-spacing:-.02em;color:var(--text);display:flex;align-items:center;gap:9px}
.nav-logo .logo-accent{color:var(--cyan)}
.logo-img{height:28px;width:28px;border-radius:7px;object-fit:cover}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{color:var(--text-2);font-size:14px;font-weight:500;transition:color .2s;letter-spacing:.01em}
.nav-links a:hover,.nav-links a.active{color:var(--text);text-decoration:none}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-cta{background:linear-gradient(135deg,var(--cyan),var(--violet-bright));color:var(--text-inv);padding:8px 18px;border-radius:8px;font-size:13px;font-weight:700;transition:opacity .2s,transform .15s,box-shadow .2s;box-shadow:0 0 20px rgba(0,212,255,.25)}
.nav-cta:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 0 30px rgba(0,212,255,.4);text-decoration:none;color:var(--text-inv)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.hamburger span{width:22px;height:2px;background:var(--text-2);border-radius:2px;transition:.3s}
.mobile-nav{display:none;position:fixed;top:62px;left:0;right:0;background:rgba(13,17,23,.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:20px 24px;flex-direction:column;gap:16px;z-index:299}
.mobile-nav.open{display:flex}
.mobile-nav a{color:var(--text);font-size:16px;font-weight:500}
.page-wrap{position:relative;z-index:1}
.breadcrumb{max-width:840px;margin:24px auto 0;padding:0 24px;font-size:12.5px;color:var(--text-3);display:flex;gap:8px;align-items:center;flex-wrap:wrap;font-family:var(--font-mono)}
.breadcrumb a{color:var(--text-3);transition:color .2s}
.breadcrumb a:hover{color:var(--cyan);text-decoration:none}
.bc-sep{color:var(--border-bright)}
.article-hdr{max-width:840px;margin:20px auto 0;padding:0 24px}
.badge-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px}
.badge{display:inline-flex;align-items:center;background:rgba(0,212,255,.08);color:var(--cyan);border:1px solid rgba(0,212,255,.2);font-size:11px;font-weight:700;letter-spacing:.06em;padding:5px 12px;border-radius:20px;text-transform:uppercase;font-family:var(--font-mono)}
.badge-read{background:rgba(0,229,160,.08);color:var(--green);border-color:rgba(0,229,160,.2)}
.badge-date{background:rgba(255,179,71,.08);color:var(--amber);border-color:rgba(255,179,71,.2)}
.article-title{font-size:clamp(28px,5vw,46px);font-weight:700;line-height:1.16;color:var(--text);margin-bottom:16px;letter-spacing:-.025em}
.title-glow{background:linear-gradient(135deg,var(--cyan),var(--violet-bright));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.article-intro{font-size:18.5px;color:var(--text-2);line-height:1.65;margin-bottom:22px}
.article-meta{display:flex;align-items:center;gap:14px;flex-wrap:wrap;font-size:12.5px;color:var(--text-3);padding-bottom:22px;border-bottom:1px solid var(--border)}
.meta-author{display:flex;align-items:center;gap:10px}
.meta-avatar{width:34px;height:34px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,var(--cyan),var(--violet-bright));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:var(--text-inv);font-family:var(--font-display);position:relative;overflow:hidden}
.meta-avatar img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%}
.meta-name{font-weight:600;color:var(--text-2)}
.meta-sep{color:var(--border-bright)}
.hero-wrap{max-width:840px;margin:28px auto;padding:0 24px}
.hero-box{width:100%;border-radius:var(--radius);overflow:hidden;border:1px solid var(--border);background:var(--bg-card);box-shadow:var(--shadow-card),var(--glow-cyan);line-height:0}
.hero-box img{width:100%;height:auto;display:block}
.toc-box{max-width:840px;margin:0 auto 8px;padding:0 24px}
.toc{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:22px 24px;box-shadow:var(--shadow-card)}
.toc-title{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:14px;display:flex;align-items:center;gap:7px;font-family:var(--font-mono)}
.toc-title::before{content:'';width:3px;height:13px;background:var(--cyan);border-radius:2px;display:inline-block;box-shadow:0 0 8px var(--cyan)}
.toc ol{margin-left:0;list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:5px 18px;counter-reset:tocnum}
.toc li{counter-increment:tocnum}
.toc a{color:var(--text-2);font-size:14px;transition:color .2s;display:flex;gap:8px;padding:3px 0}
.toc a::before{content:counter(tocnum,'0'counter(tocnum));font-family:var(--font-mono);color:var(--cyan);font-weight:700;font-size:11.5px;min-width:18px;opacity:.7}
.toc a:hover{color:var(--cyan);text-decoration:none}
.layout{max-width:840px;margin:0 auto;padding:36px 24px 80px}
.prose h2{font-size:25px;font-weight:700;color:var(--text);margin:52px 0 16px;letter-spacing:-.02em;scroll-margin-top:88px;display:flex;align-items:center;gap:12px}
.prose h2 .h2-num{font-family:var(--font-mono);font-size:12px;color:var(--cyan);font-weight:700;background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.2);padding:3px 9px;border-radius:6px;letter-spacing:.05em}
.prose h3{font-size:18px;font-weight:600;color:var(--text);margin:24px 0 10px;font-family:var(--font-display)}
.prose p{margin-bottom:20px;color:var(--text-2)}
.prose strong{color:var(--text);font-weight:600}
.prose ul,.prose ol{margin:0 0 20px 20px}
.prose li{margin-bottom:9px;color:var(--text-2)}
.key-takeaways{background:var(--bg-card);border:1px solid var(--border);border-left:3px solid var(--cyan);border-radius:0 var(--radius) var(--radius) 0;padding:22px 26px;margin:24px 0;box-shadow:var(--shadow-card)}
.kt-title{font-family:var(--font-mono);font-weight:700;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:14px}
.key-takeaways ul{margin:0;list-style:none}
.key-takeaways li{display:flex;gap:10px;margin-bottom:9px;font-size:15px;color:var(--text-2)}
.key-takeaways li:last-child{margin-bottom:0}
.key-takeaways li::before{content:'//';color:var(--cyan);flex-shrink:0;font-weight:700;font-family:var(--font-mono);font-size:12px;opacity:.7}
.key-takeaways p{color:var(--text);font-size:16px;margin-bottom:10px}
.trivia-box{background:rgba(255,179,71,.05);border:1px solid rgba(255,179,71,.2);border-radius:var(--radius);padding:20px 24px;margin:28px 0;display:flex;gap:14px;align-items:flex-start}
.trivia-icon{flex-shrink:0;width:36px;height:36px;border-radius:10px;background:rgba(255,179,71,.12);border:1px solid rgba(255,179,71,.3);display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-weight:700;font-size:12px;color:var(--amber)}
.trivia-box h4{font-family:var(--font-mono);font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--amber);margin-bottom:6px}
.trivia-box p{margin:0;color:var(--text-2);font-size:14.5px;line-height:1.65}
.use-cases{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:22px 0}
.use-case{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;transition:border-color .2s,transform .2s,box-shadow .2s;position:relative;overflow:hidden}
.use-case::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);opacity:0;transition:opacity .3s}
.use-case:hover{border-color:var(--border-bright);transform:translateY(-3px);box-shadow:0 8px 30px rgba(0,0,0,.3),0 0 20px rgba(0,212,255,.08)}
.use-case:hover::before{opacity:1}
.uc-icon{font-size:13px;color:var(--cyan);font-style:normal;font-weight:700;font-family:var(--font-mono);margin-bottom:10px;display:block}
.use-case h3{font-size:14.5px;font-weight:600;color:var(--text);margin-bottom:5px;font-family:var(--font-display)}
.use-case p{font-size:13px;color:var(--text-3);margin:0;line-height:1.55}
.mistake{background:rgba(255,100,100,.05);border-left:2px solid rgba(255,100,100,.4);border-radius:0 10px 10px 0;padding:13px 16px;margin-bottom:10px}
.mistake strong{color:#FF6B6B}
.fix-line{margin-top:7px;color:var(--green);font-size:13.5px;display:flex;align-items:flex-start;gap:7px}
.fix-line::before{content:'OK';flex-shrink:0;font-weight:700;font-family:var(--font-mono);font-size:10px;background:rgba(0,229,160,.15);border:1px solid rgba(0,229,160,.3);padding:1px 5px;border-radius:4px;margin-top:2px}
.steps{margin:26px 0;display:flex;flex-direction:column;gap:10px}
.step{display:flex;gap:16px;align-items:flex-start;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:18px 20px;transition:border-color .2s,transform .2s;cursor:default}
.step:hover{border-color:var(--cyan);transform:translateX(4px);box-shadow:0 0 20px rgba(0,212,255,.12)}
.step-num{flex-shrink:0;width:34px;height:34px;background:linear-gradient(135deg,var(--cyan),var(--violet-bright));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--text-inv);font-family:var(--font-display);box-shadow:0 0 16px rgba(0,212,255,.3)}
.step-body h3{margin:0 0 4px;font-size:15.5px;color:var(--text);font-family:var(--font-display)}
.step-body p{margin:0;font-size:14px;color:var(--text-2);line-height:1.6}
.wf-builder{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:24px 26px;margin:28px 0;box-shadow:var(--shadow-card)}
.wf-title{font-family:var(--font-mono);font-weight:700;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--cyan);margin-bottom:4px}
.wf-sub{font-size:14px;color:var(--text-3);margin-bottom:18px}
.wf-slots{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:18px}
.wf-slot{background:var(--bg-3);border:1px dashed var(--border-bright);border-radius:10px;padding:12px 10px;text-align:center;cursor:pointer;transition:all .2s;min-height:76px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;user-select:none}
.wf-slot:hover{border-color:var(--cyan);background:rgba(0,212,255,.05)}
.wf-slot.filled{border-style:solid;border-color:var(--cyan);background:rgba(0,212,255,.08)}
.wf-slot.filled .wf-slot-label{color:var(--cyan)}
.wf-slot.active-slot{outline:2px solid var(--violet-bright);outline-offset:2px}
.wf-slot-time{font-family:var(--font-mono);font-size:10px;color:var(--text-3);font-weight:700}
.wf-slot-label{font-size:12px;color:var(--text-3);font-weight:600;line-height:1.3}
.wf-section-label{font-family:var(--font-mono);font-size:11px;color:var(--text-3);letter-spacing:.05em;margin-bottom:8px;margin-top:4px}
.wf-tools{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px}
.wf-tool{background:var(--bg-3);border:1px solid var(--border-bright);border-radius:8px;padding:7px 13px;font-size:12.5px;color:var(--text-2);cursor:pointer;transition:all .2s;font-weight:500;user-select:none}
.wf-tool:hover{border-color:var(--cyan);color:var(--cyan)}
.wf-tool.selected{background:rgba(0,212,255,.1);border-color:var(--cyan);color:var(--cyan)}
.wf-output{background:var(--bg-3);border:1px solid var(--border-bright);border-radius:10px;padding:14px 16px;font-size:13.5px;color:var(--text-2);min-height:60px;font-family:var(--font-mono);line-height:1.65;white-space:pre-line}
.wf-actions{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.wf-btn{background:linear-gradient(135deg,var(--cyan),var(--violet-bright));color:var(--text-inv);border:none;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:700;cursor:pointer;transition:opacity .2s,transform .15s}
.wf-btn:hover{opacity:.88;transform:translateY(-1px)}
.wf-btn-ghost{background:transparent;border:1px solid var(--border-bright);color:var(--text-2);border-radius:8px;padding:9px 16px;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.wf-btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}
.faq{margin:14px 0}
details{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:8px;overflow:hidden;transition:border-color .2s}
details[open]{border-color:var(--border-bright)}
summary{padding:16px 20px;cursor:pointer;font-weight:600;font-size:15.5px;color:var(--text);list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px;user-select:none;font-family:var(--font-display)}
summary::-webkit-details-marker{display:none}
summary::after{content:'+';color:var(--cyan);font-size:20px;font-weight:300;flex-shrink:0;font-family:var(--font-mono)}
details[open] summary::after{content:'minus'}
.faq-body{padding:0 20px 16px;color:var(--text-2);font-size:14.5px;line-height:1.7}
.author-box{display:flex;gap:14px;align-items:flex-start;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin:44px 0 0;box-shadow:var(--shadow-card)}
.author-box h3{font-size:14.5px;font-family:var(--font-display);margin-bottom:4px;color:var(--text)}
.author-box p{font-size:13.5px;color:var(--text-3);margin:0;line-height:1.6}
.share-section{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:22px;margin:28px 0 0;text-align:center}
.share-title{font-size:15px;font-weight:600;color:var(--text);margin-bottom:14px;font-family:var(--font-display)}
.share-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.share-btn{display:flex;align-items:center;gap:7px;padding:9px 16px;border-radius:8px;border:1px solid var(--border);font-size:12.5px;font-weight:600;transition:all .2s;cursor:pointer;background:var(--bg-3);color:var(--text-2)}
.share-btn:hover{transform:translateY(-2px);text-decoration:none;border-color:var(--cyan);color:var(--cyan);box-shadow:0 0 14px rgba(0,212,255,.15)}
.newsletter{background:var(--bg-card);border:1px solid var(--border);border-radius:20px;padding:40px;margin:52px 0 0;text-align:center;position:relative;overflow:hidden;box-shadow:var(--shadow-card)}
.newsletter::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--violet-bright),var(--green))}
.newsletter::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0,rgba(0,212,255,.06),transparent 60%);pointer-events:none}
.newsletter h2{font-size:23px;font-weight:700;color:var(--text);margin-bottom:8px;font-family:var(--font-display)}
.newsletter p{color:var(--text-2);margin-bottom:22px;font-size:15px}
.nl-form{display:flex;gap:10px;max-width:420px;margin:0 auto}
.nl-input{flex:1;background:var(--bg-3);border:1px solid var(--border-bright);border-radius:9px;padding:12px 15px;color:var(--text);font-size:14px;outline:none;transition:border-color .2s,box-shadow .2s}
.nl-input::placeholder{color:var(--text-3)}
.nl-input:focus{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(0,212,255,.1)}
.nl-btn{background:linear-gradient(135deg,var(--cyan),var(--violet-bright));color:var(--text-inv);padding:12px 20px;border-radius:9px;border:none;cursor:pointer;font-size:13.5px;font-weight:700;white-space:nowrap;transition:opacity .2s,transform .15s,box-shadow .2s;box-shadow:0 0 20px rgba(0,212,255,.25)}
.nl-btn:hover{opacity:.9;transform:translateY(-1px);box-shadow:0 0 30px rgba(0,212,255,.4)}
.nl-note{font-size:11.5px;color:var(--text-3);margin:10px 0 0}
.nl-social{display:flex;gap:10px;justify-content:center;margin-top:20px;flex-wrap:wrap}
.nl-soc{display:flex;align-items:center;gap:6px;font-size:12.5px;font-weight:600;padding:8px 14px;border-radius:8px;border:1px solid var(--border);color:var(--text-2);transition:all .2s;background:var(--bg-3)}
.nl-soc:hover{transform:translateY(-2px);text-decoration:none;border-color:var(--cyan);color:var(--cyan)}
.related{margin:44px 0 0}
.related-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:16px;font-family:var(--font-display)}
.related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.rel-card{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;transition:border-color .2s,transform .2s;cursor:pointer;display:block}
.rel-card:hover{border-color:var(--border-bright);transform:translateY(-3px);text-decoration:none;box-shadow:0 8px 24px rgba(0,0,0,.3)}
.rel-tag{font-size:10.5px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--cyan);margin-bottom:7px;font-family:var(--font-mono)}
.rel-title{font-size:13.5px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:7px;font-family:var(--font-display)}
.rel-read{font-size:11.5px;color:var(--text-3);font-family:var(--font-mono)}
footer{background:var(--bg-2);border-top:1px solid var(--border);padding:56px 24px 28px;position:relative;z-index:1;overflow:hidden}
.footer-aura{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none;animation:footerDrift ease-in-out infinite}
.footer-aura-1{width:480px;height:480px;background:radial-gradient(circle,rgba(0,212,255,.10),transparent 65%);top:-220px;left:6%;animation-duration:16s}
.footer-aura-2{width:420px;height:420px;background:radial-gradient(circle,rgba(123,94,167,.14),transparent 65%);top:-180px;right:8%;animation-duration:20s;animation-delay:-6s}
.footer-aura-3{width:380px;height:380px;background:radial-gradient(circle,rgba(0,229,160,.08),transparent 65%);bottom:-160px;left:50%;animation-duration:18s;animation-delay:-10s}
.footer-aura-4{width:320px;height:320px;background:radial-gradient(circle,rgba(255,179,71,.08),transparent 65%);top:40%;left:-100px;animation-duration:22s;animation-delay:-4s}
@keyframes footerDrift{0%,100%{transform:translate(0,0)}50%{transform:translate(40px,26px)}}
.footer-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:2.2fr 1fr 1fr 1fr;gap:44px;position:relative;z-index:1}
.footer-logo{font-size:19px;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:9px;color:var(--text);font-family:var(--font-display)}
.footer-logo .accent{background:linear-gradient(90deg,var(--cyan),var(--violet-bright),var(--green),var(--amber),var(--pink),var(--cyan));background-size:400% 100%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:accentShift 8s linear infinite}
@keyframes accentShift{0%{background-position:0% 0}100%{background-position:400% 0}}
.footer-brand p{color:var(--text-3);font-size:13.5px;line-height:1.7;margin-bottom:18px}
.footer-social{display:flex;gap:8px;flex-wrap:wrap}
.fs-btn{display:flex;align-items:center;gap:6px;padding:8px 13px;border-radius:8px;border:1px solid var(--border);font-size:12.5px;font-weight:600;color:var(--text-2);transition:all .2s;background:var(--bg-3)}
.fs-btn:hover{transform:translateY(-2px);text-decoration:none;border-color:var(--cyan);color:var(--text-inv);background:linear-gradient(135deg,var(--cyan),var(--violet-bright));box-shadow:0 0 16px rgba(0,212,255,.3)}
.footer-col h4{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text);margin-bottom:14px;font-family:var(--font-mono)}
.footer-col ul{list-style:none}
.footer-col li{margin-bottom:9px}
.footer-col a{color:var(--text-3);font-size:13.5px;transition:color .2s}
.footer-col a:hover{color:var(--cyan);text-decoration:none}
.footer-bottom{max-width:1100px;margin:40px auto 0;padding-top:20px;position:relative;display:flex;justify-content:space-between;align-items:center;font-size:12.5px;color:var(--text-3);flex-wrap:wrap;gap:10px;z-index:1}
.footer-bottom::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--cyan),var(--violet-bright),var(--green),var(--amber),var(--pink),var(--cyan));background-size:300% 100%;animation:footerShimmer 8s linear infinite}
@keyframes footerShimmer{0%{background-position:0% 0}100%{background-position:300% 0}}
.footer-bottom-links{display:flex;gap:18px}
.footer-bottom-links a{color:var(--text-3);transition:color .2s}
.footer-bottom-links a:hover{color:var(--cyan);text-decoration:none}
#back-top{position:fixed;bottom:26px;right:26px;background:linear-gradient(135deg,var(--cyan),var(--violet-bright));color:var(--text-inv);width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;opacity:0;pointer-events:none;transition:opacity .3s,transform .3s;cursor:pointer;border:none;box-shadow:0 0 20px rgba(0,212,255,.3);z-index:200;font-weight:700}
#back-top.visible{opacity:1;pointer-events:all}
#back-top:hover{transform:scale(1.1) translateY(-2px);box-shadow:0 0 30px rgba(0,212,255,.5)}
.reveal{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}}
#side-popup{position:fixed;bottom:88px;right:26px;z-index:500;width:260px;background:var(--bg-card);border:1px solid var(--border-bright);border-radius:16px;padding:18px;box-shadow:var(--shadow-card),0 0 40px rgba(0,212,255,.15);transform:translateX(320px);opacity:0;transition:transform .45s cubic-bezier(.22,1,.36,1),opacity .35s ease;pointer-events:none;overflow:hidden}
#side-popup.show{transform:translateX(0);opacity:1;pointer-events:all}
#side-popup::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--cyan),var(--violet-bright))}
.sp-close{position:absolute;top:10px;right:12px;background:none;border:none;color:var(--text-3);cursor:pointer;font-size:16px;padding:2px;transition:color .2s;font-family:var(--font-mono)}
.sp-close:hover{color:var(--text)}
.sp-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,rgba(0,212,255,.15),rgba(123,94,167,.15));border:1px solid rgba(0,212,255,.2);display:flex;align-items:center;justify-content:center;margin-bottom:10px;font-family:var(--font-mono);font-weight:700;font-size:14px;color:var(--cyan)}
.sp-title{font-family:var(--font-display);font-weight:700;font-size:14px;color:var(--text);margin-bottom:5px}
.sp-text{font-size:12.5px;color:var(--text-3);line-height:1.5;margin-bottom:12px}
.sp-input{width:100%;background:var(--bg-3);border:1px solid var(--border-bright);border-radius:8px;padding:9px 12px;color:var(--text);font-size:12.5px;outline:none;margin-bottom:8px;transition:border-color .2s}
.sp-input:focus{border-color:var(--cyan)}
.sp-btn{width:100%;background:linear-gradient(135deg,var(--cyan),var(--violet-bright));color:var(--text-inv);border:none;border-radius:8px;padding:9px;font-size:12.5px;font-weight:700;cursor:pointer;transition:opacity .2s,transform .15s}
.sp-btn:hover{opacity:.9;transform:translateY(-1px)}
.sp-note{font-size:10.5px;color:var(--text-3);text-align:center;margin-top:6px;font-family:var(--font-mono)}
.scanline{position:fixed;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);opacity:.06;animation:scanDown 8s linear infinite;pointer-events:none;z-index:1}
@keyframes scanDown{0%{top:-2px}100%{top:100vh}}
@media(max-width:900px){.use-cases{grid-template-columns:repeat(2,1fr)}.related-grid{grid-template-columns:repeat(2,1fr)}.footer-inner{grid-template-columns:1fr 1fr}.nav-links,.nav-cta{display:none}.hamburger{display:flex}.toc ol{grid-template-columns:1fr}.wf-slots{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.use-cases{grid-template-columns:1fr}.related-grid{grid-template-columns:1fr}.footer-inner{grid-template-columns:1fr}.nl-form{flex-direction:column}.footer-bottom{flex-direction:column;text-align:center}#side-popup{right:12px;bottom:80px;width:240px}.article-intro{font-size:16.5px}body{font-size:16px}.wf-slots{grid-template-columns:1fr 1fr}}
</style>
</head>
