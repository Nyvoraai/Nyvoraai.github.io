<script>
(function(){
  if(window.matchMedia('(prefers-reduced-motion:reduce)').matches)return;
  const f=document.getElementById('starField');
  for(let i=0;i<120;i++){const s=document.createElement('div');s.className='star';const sz=Math.random()*1.8+0.4;s.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;top:'+Math.random()*100+'%;animation-duration:'+(2+Math.random()*4)+'s;animation-delay:'+(-Math.random()*4)+'s;opacity:'+(0.1+Math.random()*0.5);f.appendChild(s);}
})();
(function(){
  if(window.matchMedia('(prefers-reduced-motion:reduce)').matches)return;
  const w=document.getElementById('orbField');const colors=['rgba(0,212,255,0.5)','rgba(123,94,167,0.5)','rgba(0,229,160,0.4)'];
  for(let i=0;i<12;i++){const o=document.createElement('div');o.className='orb';const sz=3+Math.random()*6,dur=12+Math.random()*16,delay=-Math.random()*dur;o.style.cssText='width:'+sz+'px;height:'+sz+'px;left:'+Math.random()*100+'%;background:'+colors[i%3]+';filter:blur(1px);animation-duration:'+dur+'s;animation-delay:'+delay+'s;box-shadow:0 0 '+(sz*2)+'px '+colors[i%3];w.appendChild(o);}
})();
let popupShown=false,popupClosed=false;
window.addEventListener('scroll',function(){
  const d=document.documentElement;
  const pct=d.scrollTop/(d.scrollHeight-d.clientHeight)*100;
  document.getElementById('progress').style.width=pct+'%';
  document.getElementById('back-top').classList.toggle('visible',d.scrollTop>400);
  if(pct>40&&!popupClosed&&!popupShown){popupShown=true;setTimeout(function(){document.getElementById('side-popup').classList.add('show');},400);}
});
const reveals=document.querySelectorAll('.reveal');
const io=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target);}});},{threshold:.1});
reveals.forEach(function(r){io.observe(r);});
function toggleMenu(){document.getElementById('mobileNav').classList.toggle('open');}
function copyLink(){
  navigator.clipboard.writeText(window.location.href).then(function(){
    var btn=document.querySelector('.share-btn[onclick="copyLink()"]');
    if(!btn)return;var o=btn.textContent;btn.textContent='Copied!';btn.style.color='var(--green)';
    setTimeout(function(){btn.textContent=o;btn.style.color='';},2000);
  });
}
var slots=new Array(6).fill(null);
var activeSlot=null;
var times=['6 to 8 AM','8 to 10 AM','10 AM to 12 PM','12 to 2 PM','2 to 4 PM','4 to 6 PM'];
function selectSlot(idx){
  activeSlot=idx;
  document.querySelectorAll('.wf-slot').forEach(function(el,i){el.classList.toggle('active-slot',i===idx);});
  document.getElementById('wfOutput').textContent=slots[idx]?'Slot '+(idx+1)+' currently assigned: '+slots[idx]+'. Click a different task to reassign it.':'Slot '+(idx+1)+' selected ('+times[idx]+'). Now click a task below to assign it.';
}
function assignTask(el,task){
  if(activeSlot===null){document.getElementById('wfOutput').textContent='Pick a time block first, then click a task.';return;}
  slots[activeSlot]=task;
  document.getElementById('sl'+activeSlot).textContent=task;
  document.querySelectorAll('.wf-slot')[activeSlot].classList.add('filled');
  document.getElementById('wfOutput').textContent='Assigned "'+task+'" to '+times[activeSlot]+'.';
  document.querySelectorAll('.wf-tool').forEach(function(t){t.classList.remove('selected');});
  el.classList.add('selected');
}
function generateWorkflow(){
  var filled=slots.filter(Boolean);
  if(filled.length===0){document.getElementById('wfOutput').textContent='Add at least one task before generating your workflow.';return;}
  var out='YOUR AI DAILY WORKFLOW\n';
  out+='--------------------------------\n';
  slots.forEach(function(t,i){if(t)out+=times[i]+': '+t+'\n';});
  out+='\n'+filled.length+' block'+(filled.length>1?'s':'')+' assigned. Copy this into your notes or task manager and tweak it to fit your actual day.';
  document.getElementById('wfOutput').textContent=out;
}
function resetWorkflow(){
  slots=new Array(6).fill(null);activeSlot=null;
  for(var i=0;i<6;i++){document.getElementById('sl'+i).textContent='Empty — click to select';}
  document.querySelectorAll('.wf-slot').forEach(function(el){el.classList.remove('filled','active-slot');});
  document.querySelectorAll('.wf-tool').forEach(function(el){el.classList.remove('selected');});
  document.getElementById('wfOutput').textContent='Select a time block above, then click a task to assign it.';
}
function handleNewsletter(e,form){
  e.preventDefault();var btn=form.querySelector('.nl-btn');btn.textContent='Sending...';btn.style.opacity='.7';
  fetch(form.action,{method:'POST',body:new FormData(form),headers:{'Accept':'application/json'}})
    .then(function(r){if(r.ok){btn.textContent='Subscribed!';btn.style.background='var(--green)';form.reset();}else{btn.textContent='Try again';btn.style.opacity='1';}})
    .catch(function(){btn.textContent='Try again';btn.style.opacity='1';});
}
function closePopup(){document.getElementById('side-popup').classList.remove('show');popupClosed=true;}
function handlePopupSubmit(e,form){
  e.preventDefault();var btn=form.querySelector('.sp-btn');btn.textContent='Sending...';
  fetch(form.action,{method:'POST',body:new FormData(form),headers:{'Accept':'application/json'}})
    .then(function(r){
      if(r.ok){document.getElementById('side-popup').innerHTML='<div style="padding:8px 0;text-align:center"><div style="font-family:var(--font-mono);font-size:12px;color:var(--green);font-weight:700;margin-bottom:6px">Subscribed!</div><div style="font-size:12px;color:var(--text-3)">Check your inbox soon.</div></div>';setTimeout(closePopup,2400);}
      else{btn.textContent='Try again';}
    }).catch(function(){btn.textContent='Try again';});
}
setTimeout(function(){if(!popupShown&&!popupClosed){popupShown=true;document.getElementById('side-popup').classList.add('show');}},8000);
</script>
</body>
</html>
